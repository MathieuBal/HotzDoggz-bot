# ──────────────────────────────────────────────────────────────────────────
# HotzDogz - Bot de gestion · variables d'environnement (exemple)
# Copier ce fichier en `.env` et renseigner les valeurs. NE JAMAIS committer `.env`.
# ──────────────────────────────────────────────────────────────────────────

# ── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
# Fuseau horaire de la semaine comptable (cf. CDC §14 : Europe/Paris par defaut)
TIMEZONE=Europe/Paris

# ── Discord ────────────────────────────────────────────────────────────────
# Token du bot (Developer Portal > Bot > Reset Token). SECRET.
DISCORD_TOKEN=
# Application (client) ID, pour l'enregistrement des slash commands.
DISCORD_CLIENT_ID=
# ID du serveur (guild). En MVP mono-serveur, sert aussi a l'enregistrement
# instantane des commandes de guilde.
DISCORD_GUILD_ID=

# ── Base de donnees (PostgreSQL) ───────────────────────────────────────────
# En local avec docker-compose, l'hote est `postgres` (nom du service).
DATABASE_URL=postgresql://hotzdogz:hotzdogz@localhost:5432/hotzdogz?schema=public
# EN PROD (VPS) : definis un mot de passe FORT ici. docker-compose l'injecte a la
# fois dans Postgres et dans l'URL du bot. Laisse vide en dev (defaut = hotzdogz).
POSTGRES_PASSWORD=

# ── Healthcheck du conteneur (optionnel) ───────────────────────────────────
# Fichier de battement de coeur et age max avant de considerer le bot "zombie".
# Valeurs par defaut raisonnables ; a ne changer qu'en cas de besoin.
# HEALTHCHECK_FILE=/tmp/hotzdoggz-heartbeat
# HEALTHCHECK_MAX_AGE_MS=90000

# ── Seed de configuration (optionnel, §5.1) ────────────────────────────────
# IDs des roles de grade/direction. Renseignes => le seed cree les GradeRate.
ROLE_DIRECTEUR=
ROLE_CO_DIRECTEUR=
ROLE_CHEF_EQUIPE=
ROLE_EXPERIMENTE=
ROLE_NOVICE=
ROLE_STAGIAIRE=

# IDs des salons (Forum de controle, comptabilite, paies, logs, tableau hebdo).
CHANNEL_CONTROL=
CHANNEL_ACCOUNTING=
CHANNEL_PAYROLL=
CHANNEL_LOGS=
CHANNEL_WEEKLY_BOARD=

# ── Stockage durable des preuves (§5.3) ────────────────────────────────────
# Repertoire local par defaut (copie durable des captures). Doit etre persistant.
STORAGE_DIR=./storage
# Retention des preuves images en jours : au-dela, purge automatique quotidienne
# (anti-saturation disque). Les photos durables (menu, vehicules) sont preservees.
# 30 = "garder ~un mois". Mettre 7 pour une purge hebdomadaire.
STORAGE_RETENTION_DAYS=30

# Backend S3 (MinIO, Cloudflare R2, AWS S3...) — non encore implemente : si
# defini, le bot se replie sur le stockage fichier en attendant.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
