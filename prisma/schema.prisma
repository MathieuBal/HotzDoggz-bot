// ════════════════════════════════════════════════════════════════════════════
// HotzDoggz · Modele de donnees (CDC §9)
// PostgreSQL est la source officielle ; Discord n'est que l'interface.
// Principes : montants entiers, append-only pour l'audit/le journal financier,
// idempotence (threadId unique), snapshots figes a la validation.
// ════════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ───────────────────────────────────────────────────────────────────

enum EmployeeStatus {
  ACTIVE
  ARCHIVED
}

enum AccountingWeekStatus {
  OPEN
  CLOSED
}

/// Statuts internes de la vente (CDC Annexe B). Plus precis que les tags Discord,
/// qui ne sont qu'une representation visuelle simplifiee.
enum SaleStatus {
  SOUMISE
  INCOMPLETE
  EN_VERIFICATION
  VALIDEE
  INTEGREE_A_LA_PAIE
  PAYEE
  REFUSEE
  ANNULEE
}

enum PayrollStatus {
  PENDING // a payer
  PAID
}

/// Niveau de risque anti-fraude d'une vente (CDC §10.3 : controle d'integrite).
/// Affiche un repere visuel sur la fiche de controle pour prioriser l'attention.
enum SaleRisk {
  CLEAN // 🟢 rien a signaler
  SUSPECT // 🟠 a regarder (volume eleve, cadence rapprochee)
  FLAGGED // 🔴 alerte forte (preuve deja utilisee)
}

/// Type de preuve jointe (CDC §4.1).
enum AttachmentType {
  COFFRE_PLEIN // avant la vente
  COFFRE_VIDE // apres la vente
}

/// Cycle de vie d'une commande client (negociee par la direction).
enum ClientOrderStatus {
  OUVERTE // en cours de production (accepte des contributions)
  LIVREE // livree au client, en attente de paiement
  PAYEE // payee : revenu integre a la semaine, cloturee
  ANNULEE
}

/// Etat d'une contribution de production a une commande client.
enum OrderContributionStatus {
  ACTIVE
  ANNULEE
}

/// Visibilite d'un avis client (modere par suppression du message par la direction).
enum ReviewStatus {
  VISIBLE
  REMOVED
}

/// Ecritures du journal financier append-only (CDC §6.3).
enum LedgerEntryType {
  SALE_REVENUE
  SALARY_LIABILITY
  RESERVE_ALLOCATION
  BONUS_ALLOCATION
  DIRECTION_ALLOCATION
  PAYMENT
  ADJUSTMENT
}

/// Cle interne d'un tag de Forum, mappee vers l'ID Discord propre a chaque salon
/// (les tags ne sont pas dupliques automatiquement entre Forums - CDC §5.1).
enum ForumTagKey {
  NOUVELLE_VENTE
  A_VERIFIER
  A_COMPLETER
  VALIDEE
  PAYEE
  REFUSEE
}

// ── Configuration ───────────────────────────────────────────────────────────

/// Une configuration active par serveur Discord. Les rôles et salons sont
/// reference par identifiant Discord, jamais par nom (CDC §2.1).
model GuildConfig {
  id       String @id @default(cuid())
  guildId  String @unique
  timezone String @default("Europe/Paris")

  // Roles (IDs Discord)
  roleDirecteur   String?
  roleCoDirecteur String?
  roleChefEquipe  String?
  roleExperimente String?
  roleNovice      String?
  roleStagiaire   String?
  roleClient      String? // role attribue aux visiteurs ayant accepte le reglement

  // Salons (IDs Discord)
  channelControl        String? // Forum prive de controle (1 fiche / vente)
  channelAccounting     String? // comptabilite
  channelPayroll        String? // paies
  channelLogs           String? // logs-et-archives
  channelWeeklyBoard    String? // tableau-de-bord-hebdo
  channelCompanyBoard   String? // salon employe "Developpement de l'entreprise"
  channelOrders         String? // salon direction "commandes client a realiser"
  channelReviews        String? // salon public "avis clients"
  channelPartnerships   String? // salon employe "objectifs partenariats" (live)
  channelGuideDirection String? // salon tuto direction (guide des commandes)
  channelGuideEmployee  String? // salon tuto employes (process)
  channelWelcome        String? // salon d'accueil des nouveaux arrivants
  channelReglement      String? // salon reglement (porte le bouton de validation)
  channelMenuBoard      String? // salon public "menu et tarifs" (maintenu par le bot)
  channelEvent          String? // salon "evenement" (vitrine maintenue par le bot)
  channelBonusBoard     String? // salon employe "prime" (repartition degressive live)
  channelPlanning       String? // salon employe "planning" (agenda commandes + positionnement)
  channelStock          String? // salon employe "stock" (saucisses par vehicule + peremption)
  channelGarage         String? // salon "garage" (catalogue des vehicules + attribution)
  channelPalmares       String? // salon "palmarès" (classement + prestige, permanent)

  // Vitrines editables (texte du corps ; le titre/style est gere par le bot)
  welcomeBoardText String?
  eventText        String?

  // Message d'accueil RP personnalisable ({membre} = mention du nouveau)
  welcomeMessage String?

  // Messages permanents edites par le bot (CDC §5.5 / §7.4)
  msgWeeklyEmployees  String?
  msgAccounting       String?
  msgPayroll          String?
  msgSalaryGrid       String?
  msgCompanyBoard     String? // tableau "Developpement de l'entreprise" (cote employes)
  msgOrdersBoard      String? // tableau "commandes client a realiser" (direction)
  msgReviewBoard      String? // bandeau "avis clients" (note moyenne + bouton)
  msgPartnershipBoard String? // tableau "objectifs partenariats" (cote employes)
  msgGuideDirection   String? // guide tuto direction (permanent)
  msgGuideEmployee    String? // guide tuto employes (permanent)
  msgVerification     String? // message permanent "valider le reglement" (bouton)
  msgMenuBoard        String? // menu public "menu et tarifs" (permanent)
  msgWelcomeBoard     String? // vitrine "bienvenue" (permanent)
  msgEventBoard       String? // vitrine "evenement" (permanent)
  msgBonusBoard       String? // tableau "prime" (repartition degressive, permanent)
  msgPlanningBoard    String? // agenda "planning" (commandes de la semaine, permanent)
  msgStockBoard       String? // tableau "stock" (saucisses + lots de hot dogs, permanent)
  msgGarageBoard      String? // catalogue "garage" (vehicules, permanent)
  msgPalmares         String? // tableau "palmarès" (classement + prestige, permanent)

  // Prix de vente PNJ courant (snapshote a la validation de chaque vente)
  pnjUnitPrice Int @default(210)

  // --- Leviers economiques pilotables depuis le panel (sinon valeurs par defaut) ---
  // Repartition hebdomadaire du benefice (§1.4). La part Co-directeur = le reste
  // (100 - prime - directeur), elle absorbe le residu d'arrondi : pas de champ.
  reserveRatePercent  Int @default(5) // reserve de securite sur le CA
  bonusRatePercent    Int @default(35) // prime du meilleur employe
  directorRatePercent Int @default(40) // part Directeur

  // Duree de vie d'un lot de hot dogs cuits (peremption). Defaut 6 j 17 h.
  hotdogLifetimeMinutes Int @default(9660)

  // Seuils du controle d'integrite anti-fraude (§10.3).
  fraudQuantityThreshold  Int @default(1000) // volume unitaire improbable
  fraudBurstCount         Int @default(3) // nb de ventes rapprochees = rafale
  fraudBurstWindowMinutes Int @default(10) // fenetre d'observation de la rafale

  // Fenetre du rappel de cloture (0=lundi..6=dimanche, heures locales 0-23).
  closureReminderWeekday   Int @default(6)
  closureReminderHourStart Int @default(20)
  closureReminderHourEnd   Int @default(23)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees    Employee[]
  gradeRates   GradeRate[]
  forumTags    ForumTag[]
  weeks        AccountingWeek[]
  sales        Sale[]
  payrolls     Payroll[]
  ledger       LedgerEntry[]
  auditLogs    AuditLog[]
  gradeEvents  EmployeeGradeEvent[]
  clientOrders ClientOrder[]
  reviews      Review[]
  products     Product[]
  directSales  DirectSale[]
  partners     Partner[]
  advances     SalaryAdvance[]
  events       Event[]
  vehicles     Vehicle[]
  hotdogBatches HotdogBatch[]
  employeeBadges EmployeeBadge[]
}

/// Partenaire B2B (autre org/business). Porte un objectif unique cumulatif de
/// quantite a fournir ; la progression = total livre via ses commandes payees.
model Partner {
  id              String      @id @default(cuid())
  guildConfig     GuildConfig @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId   String
  name            String
  objectiveTarget Int? // objectif de quantite (cumulatif), null = pas d'objectif
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  orders ClientOrder[]

  @@unique([guildConfigId, name])
  @@index([guildConfigId, active])
}

/// Catalogue de produits vendus en main en main (CDC : menu). Prix de detail
/// editable par la direction ; chaque vente fige le prix du moment (snapshot),
/// donc modifier un prix ne reecrit jamais les ventes passees.
model Product {
  id            String      @id @default(cuid())
  guildConfig   GuildConfig @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String
  name          String
  retailPrice   Int // prix de detail au joueur (entier, $)
  description   String? // courte accroche affichee au menu public
  imageKey      String? // cle de stockage de la photo du produit
  imageName     String? // nom de fichier d'origine (extension pour l'affichage)
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([guildConfigId, name])
  @@index([guildConfigId, active])
}

// ── Ventes main en main (facture) ───────────────────────────────────────────

/// Vente directe a un joueur (CDC : main en main). Produits du menu + photo de
/// facture, validee par la direction (verif sur le PC in-game). Le salaire suit
/// le grade (comme les commandes) ; le CA = somme des prix de detail figes.
model DirectSale {
  id            String          @id @default(cuid())
  reference     String          @unique // VD-AAAA-NNNN
  guildConfig   GuildConfig     @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String
  week          AccountingWeek? @relation(fields: [weekId], references: [id])
  weekId        String?
  employee      Employee        @relation(fields: [employeeId], references: [id])
  employeeId    String

  buyerName       String? // nom RP du client (optionnel)
  threadId        String? @unique // post du casier (si declaree par casier)
  controlThreadId String? @unique // fiche de controle

  status SaleStatus @default(SOUMISE)

  // Instantanes financiers (salaire = grade * quantite totale)
  gradeSnapshot       String?
  gradeRoleIdSnapshot String?
  salaryRateSnapshot  Int?

  // Controle d'integrite (preuve recyclee...)
  riskLevel   SaleRisk @default(CLEAN)
  riskReasons String?

  declaredAt           DateTime
  submittedAt          DateTime  @default(now())
  controllerDiscordId  String?
  validatedByDiscordId String?
  validatedAt          DateTime?
  verificationNote     String?
  refusalReason        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines       DirectSaleLine[]
  attachments DirectSaleAttachment[]

  @@index([weekId, status])
  @@index([employeeId, weekId])
}

/// Ligne d'une vente main en main : un produit, son prix de detail fige, la
/// quantite declaree puis validee (ajustable par la direction).
model DirectSaleLine {
  id                String     @id @default(cuid())
  directSale        DirectSale @relation(fields: [directSaleId], references: [id], onDelete: Cascade)
  directSaleId      String
  productId         String? // null si le produit a ete retire du menu depuis
  productName       String // libelle fige
  unitPrice         Int // prix de detail fige
  declaredQuantity  Int
  validatedQuantity Int?

  @@index([directSaleId])
}

/// Preuve (facture) d'une vente main en main (copie durable, comme §5.3).
model DirectSaleAttachment {
  id                  String         @id @default(cuid())
  directSale          DirectSale     @relation(fields: [directSaleId], references: [id], onDelete: Cascade)
  directSaleId        String
  type                AttachmentType
  discordMessageId    String
  discordAttachmentId String
  fileName            String
  size                Int
  mimeType            String
  sha256              String
  storageKey          String
  discordUrl          String?
  createdAt           DateTime       @default(now())

  @@index([directSaleId])
  @@index([sha256])
}

/// Historique des tarifs salariaux par role (CDC §6.2 : instantanes financiers).
model GradeRate {
  id            String      @id @default(cuid())
  guildConfig   GuildConfig @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String
  roleId        String // ID du role Discord
  label         String // "Chef d'equipe", "Directeur", ...
  ratePerUnit   Int // salaire par hot dog valide (entier)
  validFrom     DateTime    @default(now())
  validTo       DateTime? // null = tarif actif
  createdAt     DateTime    @default(now())

  @@index([guildConfigId, roleId])
  @@index([roleId, validTo])
}

/// Mapping cle interne -> ID de tag Discord, propre a chaque Forum (CDC §5.1).
model ForumTag {
  id             String      @id @default(cuid())
  guildConfig    GuildConfig @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId  String
  forumChannelId String
  key            ForumTagKey
  discordTagId   String
  createdAt      DateTime    @default(now())

  @@unique([forumChannelId, key])
}

// ── Employes & casiers ──────────────────────────────────────────────────────

model Employee {
  id            String         @id @default(cuid())
  guildConfig   GuildConfig    @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String
  discordUserId String         @unique
  nomRP         String
  casierForumId String?        @unique // Forum prive de l'employe (CDC §2.4)
  status        EmployeeStatus @default(ACTIVE)

  // Dernier grade salarial connu (resolu a l'ingestion) : sert a detecter les
  // promotions sans re-alerter a chaque vente.
  lastGradeRoleId String?
  lastGradeLabel  String?
  lastGradeRate   Int?

  // Multiplicateur "bracelet" (x2/x3 achete en vrai argent) : neutralise pour la
  // course a la prime (production ajustee = quantite / multiplicateur). 1 = aucun.
  bonusMultiplier Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales              Sale[]
  payrolls           Payroll[]
  gradeEvents        EmployeeGradeEvent[]
  orderContributions OrderContribution[]
  reviews            Review[]
  directSales        DirectSale[]
  advances           SalaryAdvance[]
  orderSignups       OrderSignup[]
  eventSignups       EventSignup[]
  ownedVehicles      Vehicle[]     @relation("OwnedVehicles")
  badges             EmployeeBadge[]

  // Recherche d'employes d'un serveur par statut (match par nom RP, embauches
  // de la semaine). Volume faible, mais cadre les lectures par serveur.
  @@index([guildConfigId, status])
}

enum SalaryAdvanceStatus {
  ACTIVE
  CANCELLED
}

enum EventStatus {
  ACTIVE
  CANCELLED
}

/// Vehicule de l'entreprise : contient le stock de SAUCISSES (matiere premiere,
/// non perissable). Identifie par marque + plaque.
model Vehicle {
  id            String      @id @default(cuid())
  guildConfig   GuildConfig @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String

  name      String? // petit nom (optionnel)
  make      String // marque
  plate     String // plaque d'immatriculation
  saucisses Int     @default(0) // stock de saucisses en cours
  active    Boolean @default(true)

  // Catalogue garage
  owner     Employee? @relation("OwnedVehicles", fields: [ownerId], references: [id])
  ownerId   String? // proprietaire (employe) ; null = disponible a donner
  capacity  Int       @default(0) // poids transportable (capacite de charge)
  photoKey  String? // cle de stockage de la photo
  photoName String? // nom de fichier d'origine

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batches HotdogBatch[]

  @@unique([guildConfigId, plate])
  @@index([guildConfigId, active])
}

/// Lot de hot dogs issus d'une transformation (saucisses -> hot dogs, 1:1).
/// PERISSABLE : expire 6j17h apres la production.
model HotdogBatch {
  id            String      @id @default(cuid())
  guildConfig   GuildConfig @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String
  vehicle       Vehicle?    @relation(fields: [vehicleId], references: [id])
  vehicleId     String?

  quantity  Int // quantite produite
  remaining Int // reste en stock (non ecoule)
  producedAt DateTime @default(now())
  expiresAt  DateTime // producedAt + 6j17h

  createdByDiscordId String?

  @@index([guildConfigId, remaining, expiresAt])
}

/// Evenement RP auquel HotzDoggz participe (expo, soiree, marche...). Affiche
/// dans l'agenda planning ; les employes s'y positionnent (presence/aide).
model Event {
  id            String      @id @default(cuid())
  guildConfig   GuildConfig @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String

  title       String
  startAt     DateTime // date + heure de l'evenement
  location    String?
  ourRole     String? // notre role sur place (exposant, tombola...)
  description String?
  status      EventStatus @default(ACTIVE)

  createdByDiscordId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  signups EventSignup[]

  @@index([guildConfigId, status, startAt])
}

/// Positionnement d'un employe sur un evenement (toggle).
model EventSignup {
  id         String   @id @default(cuid())
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId    String
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String
  createdAt  DateTime @default(now())

  @@unique([eventId, employeeId])
  @@index([eventId])
}

/// Avance / acompte sur salaire verse en cours de semaine (plafonne au gagne).
/// Deduit du net a payer a la cloture ; sortie tracee au journal des le versement.
model SalaryAdvance {
  id            String              @id @default(cuid())
  guildConfig   GuildConfig         @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String
  week          AccountingWeek      @relation(fields: [weekId], references: [id])
  weekId        String
  employee      Employee            @relation(fields: [employeeId], references: [id])
  employeeId    String
  amount        Int
  status        SalaryAdvanceStatus @default(ACTIVE)
  note          String?

  createdByDiscordId   String
  createdAt            DateTime  @default(now())
  cancelledAt          DateTime?
  cancelledByDiscordId String?

  @@index([weekId, employeeId])
}

/// Avis client (RP) laisse via un bouton dans le salon public. Note 1-5 + texte,
/// peut citer l'employe qui a servi. Modere par suppression du message (synchro).
model Review {
  id              String       @id @default(cuid())
  guildConfig     GuildConfig  @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId   String
  authorDiscordId String
  authorName      String
  rating          Int // 1 a 5
  comment         String
  employee        Employee?    @relation(fields: [employeeId], references: [id])
  employeeId      String?
  employeeName    String? // nom saisi (peut ne correspondre a aucun employe)
  messageId       String?      @unique // carte postee dans le salon (synchro suppression)
  status          ReviewStatus @default(VISIBLE)
  createdAt       DateTime     @default(now())

  @@index([guildConfigId, status])
  @@index([authorDiscordId, createdAt])
}

/// Changement de grade d'un employe (CDC §7 : evolutions). Alimente le tableau
/// "Developpement de l'entreprise" (promotions de la semaine). Append-only.
model EmployeeGradeEvent {
  id            String      @id @default(cuid())
  guildConfig   GuildConfig @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId    String
  fromLabel     String? // null = premier grade connu (embauche, pas une promotion)
  fromRate      Int?
  toLabel       String
  toRate        Int
  roleId        String
  createdAt     DateTime    @default(now())

  @@index([guildConfigId, createdAt])
  @@index([employeeId])
}

// ── Semaine comptable ───────────────────────────────────────────────────────

/// Une seule semaine OPEN par serveur (CDC §9.3). Garanti par `openGuildKey`
/// (= guildId tant que la semaine est ouverte, null une fois cloturee).
model AccountingWeek {
  id            String               @id @default(cuid())
  guildConfig   GuildConfig          @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String
  startAt       DateTime
  endAt         DateTime
  status        AccountingWeekStatus @default(OPEN)
  openGuildKey  String?              @unique // verrou "une seule semaine ouverte"

  // Snapshots de cloture (figes, recalculables depuis les ventes)
  totalRevenue    Int?
  totalSalaries   Int?
  reserve         Int?
  distributable   Int?
  bonus           Int?
  directorShare   Int?
  coDirectorShare Int?
  bestEmployeeId  String?

  closedAt          DateTime?
  closedByDiscordId String?
  createdAt         DateTime  @default(now())

  sales        Sale[]
  payrolls     Payroll[]
  ledger       LedgerEntry[]
  clientOrders ClientOrder[]
  directSales  DirectSale[]
  advances     SalaryAdvance[]

  // getOpenWeek (status=OPEN) est sur le chemin chaud (chaque refresh panel/tableau),
  // et la derniere semaine CLOSED est lue par ordre de endAt decroissant (export,
  // tableau "developpement"). Sans index, seq-scan d'une table qui grossit (1/semaine).
  @@index([guildConfigId, status, endAt])
}

// ── Commandes client ────────────────────────────────────────────────────────

/// Commande client negociee par la direction (CDC : ventes B2C, hors PNJ).
/// Le prix est libre (negociation) ; le revenu rejoint le CA de la semaine au
/// moment du paiement. La production est realisee a plusieurs (contributions).
model ClientOrder {
  id            String      @id @default(cuid())
  reference     String      @unique // CMD-AAAA-NNNN
  guildConfig   GuildConfig @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String

  clientName      String
  description     String?
  targetQuantity  Int // objectif de production (hot dogs)
  negotiatedPrice Int // prix total negocie (entier, $)
  deadline        DateTime?

  // Rattachement a un partenaire (objectifs partenariats), optionnel.
  partner   Partner? @relation(fields: [partnerId], references: [id])
  partnerId String?

  status ClientOrderStatus @default(OUVERTE)

  // Livraison & paiement (CDC : suivi simple paye/non-paye + preuve)
  deliveredAt                 DateTime?
  deliveredByDiscordId        String?
  paidAt                      DateTime?
  paymentCollectedByDiscordId String?
  paymentProofKey             String? // cle stockage objet de la preuve de paiement

  // Rattachement comptable : la semaine OUVERTE au moment du paiement.
  week   AccountingWeek? @relation(fields: [weekId], references: [id])
  weekId String?

  createdByDiscordId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  contributions OrderContribution[]
  signups       OrderSignup[]

  @@index([guildConfigId, status])
  @@index([weekId])
  @@index([partnerId])
}

/// Positionnement d'un employe sur une commande via l'agenda planning : signal
/// "je vais aider" (volontariat). La contribution reelle (avec preuves) reste
/// /commande contribuer. Toggle : se positionner / se retirer.
model OrderSignup {
  id         String      @id @default(cuid())
  order      ClientOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  employee   Employee    @relation(fields: [employeeId], references: [id])
  employeeId String
  createdAt  DateTime    @default(now())

  @@unique([orderId, employeeId])
  @@index([orderId])
}

/// Contribution de production d'un employe a une commande (CDC : multi-employes).
/// Saisie par la direction avec preuves. Les unites comptent dans la production
/// et le salaire de l'employe (au tarif de son grade), une fois la commande payee.
model OrderContribution {
  id            String      @id @default(cuid())
  order         ClientOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String
  guildConfigId String // denormalise pour les requetes par serveur
  employee      Employee    @relation(fields: [employeeId], references: [id])
  employeeId    String

  quantity Int
  status   OrderContributionStatus @default(ACTIVE)

  // Instantanes financiers figes a la saisie (comme une vente).
  gradeSnapshot       String?
  gradeRoleIdSnapshot String?
  salaryRateSnapshot  Int?

  // Controle d'integrite (preuves recyclees, etc.).
  riskLevel   SaleRisk @default(CLEAN)
  riskReasons String?

  recordedByDiscordId String?
  createdAt           DateTime @default(now())

  attachments OrderContributionAttachment[]

  @@index([orderId])
  @@index([employeeId])
}

/// Preuves d'une contribution (copie durable obligatoire, comme les ventes §5.3).
model OrderContributionAttachment {
  id                  String            @id @default(cuid())
  contribution        OrderContribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)
  contributionId      String
  type                AttachmentType
  discordMessageId    String
  discordAttachmentId String
  fileName            String
  size                Int
  mimeType            String
  sha256              String
  storageKey          String
  discordUrl          String?
  createdAt           DateTime          @default(now())

  @@index([contributionId])
  @@index([sha256])
}

// ── Ventes ──────────────────────────────────────────────────────────────────

model Sale {
  id            String         @id @default(cuid())
  reference     String         @unique // ex. HD-2026-0042
  guildConfig   GuildConfig    @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String
  week          AccountingWeek @relation(fields: [weekId], references: [id])
  weekId        String
  employee      Employee       @relation(fields: [employeeId], references: [id])
  employeeId    String

  threadId        String  @unique // post du casier (cle d'idempotence - CDC §4.2)
  controlThreadId String? @unique // fiche de controle (CDC §4.5)

  declaredQuantity  Int
  validatedQuantity Int?

  // Instantanes financiers figes a la declaration / validation (CDC §6.2)
  gradeSnapshot        String?
  gradeRoleIdSnapshot  String?
  salaryRateSnapshot   Int?
  pnjUnitPriceSnapshot Int?

  status SaleStatus @default(SOUMISE)

  // Controle d'integrite anti-fraude (CDC §10.3), evalue a l'ingestion.
  riskLevel   SaleRisk @default(CLEAN)
  riskReasons String? // motifs concatenes, affiches sur la fiche de controle

  declaredAt           DateTime
  submittedAt          DateTime  @default(now())
  controllerDiscordId  String? // prise en charge
  validatedAt          DateTime?
  validatedByDiscordId String?
  verificationNote     String? // note de verification PC in-game
  refusalReason        String?
  comment              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments   SaleAttachment[]
  statusHistory SaleStatusHistory[]
  ledger        LedgerEntry[]

  @@index([weekId, status])
  @@index([employeeId, weekId])
  // Anti-fraude "rafale" : compte les ventes recentes d'un employe a CHAQUE
  // declaration (chemin chaud) — Sale est append-only, l'historique croit sans purge.
  @@index([guildConfigId, employeeId, createdAt])
  // Rappel des validations en attente : filtre serveur+statut, fenetre submittedAt.
  @@index([guildConfigId, status, submittedAt])
}

/// Preuves : copie durable obligatoire en stockage objet (CDC §5.3).
model SaleAttachment {
  id                  String         @id @default(cuid())
  sale                Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId              String
  type                AttachmentType
  discordMessageId    String
  discordAttachmentId String
  fileName            String
  size                Int
  mimeType            String
  sha256              String
  storageKey          String // cle dans le stockage objet (source durable)
  discordUrl          String? // reference secondaire (URL signee, expire)
  createdAt           DateTime       @default(now())

  @@index([saleId])
  @@index([sha256]) // detection de preuves recyclees (anti-fraude, CDC §10.3)
}

/// Historique des statuts append-only (CDC §9.2).
model SaleStatusHistory {
  id              String      @id @default(cuid())
  sale            Sale        @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId          String
  fromStatus      SaleStatus?
  toStatus        SaleStatus
  authorDiscordId String?
  reason          String?
  correlationId   String?
  createdAt       DateTime    @default(now())

  @@index([saleId])
}

// ── Paies ───────────────────────────────────────────────────────────────────

/// Paie suivie par employe et par semaine, pas vente par vente (CDC §6.7).
model Payroll {
  id            String         @id @default(cuid())
  guildConfig   GuildConfig    @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String
  employee      Employee       @relation(fields: [employeeId], references: [id])
  employeeId    String
  week          AccountingWeek @relation(fields: [weekId], references: [id])
  weekId        String

  salaryAmount Int // salaire de production
  bonusAmount  Int           @default(0) // prime meilleur employe (le cas echeant)
  advancedAmount Int         @default(0) // acomptes deja verses durant la semaine
  totalAmount  Int
  status       PayrollStatus @default(PENDING)

  paidAt         DateTime?
  payerDiscordId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([employeeId, weekId])
}

// ── Journal financier & audit (append-only) ─────────────────────────────────

model LedgerEntry {
  id            String          @id @default(cuid())
  guildConfig   GuildConfig     @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String
  type          LedgerEntryType
  amount        Int // entier SIGNE : negatif = contre-passation/retrait (ADJUSTMENT d'annulation), sommer redonne le solde reel
  week          AccountingWeek? @relation(fields: [weekId], references: [id])
  weekId        String?
  sale          Sale?           @relation(fields: [saleId], references: [id])
  saleId        String?
  employeeId    String?
  payrollId     String?
  description   String?
  correlationId String?
  createdAt     DateTime        @default(now())

  @@index([weekId, type])
  @@index([saleId])
}

/// Journal d'audit : aucune action sensible sans trace (CDC §10.3).
model AuditLog {
  id              String       @id @default(cuid())
  guildConfig     GuildConfig? @relation(fields: [guildConfigId], references: [id])
  guildConfigId   String?
  action          String
  authorDiscordId String?
  entityType      String?
  entityId        String?
  before          Json?
  after           Json?
  reason          String?
  channelId       String?
  correlationId   String?
  createdAt       DateTime     @default(now())

  @@index([correlationId])
  @@index([entityType, entityId])
  // Lecture du journal (/journal, /export audit) : par serveur, du plus recent
  // au plus ancien, et filtrage par auteur.
  @@index([guildConfigId, createdAt])
  @@index([guildConfigId, authorDiscordId, createdAt])
}

/// Badge / accomplissement gagne par un employe (gamification). Les definitions
/// (cle -> libelle, seuil) vivent dans le code (badges registry) ; cette table
/// ne stocke que les badges effectivement obtenus, une fois chacun.
model EmployeeBadge {
  id            String      @id @default(cuid())
  guildConfig   GuildConfig @relation(fields: [guildConfigId], references: [id], onDelete: Cascade)
  guildConfigId String
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId    String
  badgeKey      String // cle de la definition (cf. src/modules/badges/registry)
  awardedAt     DateTime    @default(now())

  @@unique([employeeId, badgeKey]) // un badge gagne une seule fois
  @@index([guildConfigId, employeeId])
}
